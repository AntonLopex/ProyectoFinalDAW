      "descripcion": "Una crema de calabaza aterciopelada con toque de jengibre y coco, perfecta para los días fríos. Receta vegana y llena de sabor.",
      "ingredientes": [
        { "id": 1, "nombre": "Calabaza", "cantidad": "1 kg" },
        { "id": 2, "nombre": "Cebolla", "cantidad": "1 unidad" },
        { "id": 3, "nombre": "Jengibre fresco rallado", "cantidad": "2 cm" },
        { "id": 4, "nombre": "Ajo", "cantidad": "2 dientes" },
        { "id": 5, "nombre": "Leche de coco", "cantidad": "200 ml" },
        { "id": 6, "nombre": "Caldo de verduras", "cantidad": "800 ml" },
        { "id": 7, "nombre": "Aceite de oliva", "cantidad": "2 cucharadas" },
        { "id": 8, "nombre": "Sal y pimienta", "cantidad": "al gusto" },
