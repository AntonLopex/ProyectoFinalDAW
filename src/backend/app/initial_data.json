  {
    "model": "recetas.receta",
    "pk": 1,
    "fields": {
      "usuario": 2,
      "titulo": "Tortilla española clásica",
      "descripcion": "La auténtica tortilla española con patata y cebolla, jugosa por dentro y dorada por fuera. Una receta tradicional que nunca falla.",
      "ingredientes": [
        { "id": 1, "nombre": "Patatas medianas", "cantidad": "4 unidades" },
        { "id": 2, "nombre": "Cebolla", "cantidad": "1 unidad" },
        { "id": 3, "nombre": "Huevos", "cantidad": "6 unidades" },
        {
          "id": 4,
          "nombre": "Aceite de oliva virgen extra",
          "cantidad": "200 ml"
        },
        { "id": 5, "nombre": "Sal", "cantidad": "al gusto" }
      ],
      "elaboracion": [
        {
          "id": 1,
          "paso": "Pelar y cortar las patatas en láminas finas. Picar la cebolla en juliana."
        },
        {
          "id": 2,
          "paso": "Calentar el aceite en una sartén a fuego medio y pochar las patatas y la cebolla durante 20 minutos hasta que estén blandas."
        },
        {
          "id": 3,
          "paso": "Escurrir bien el aceite y mezclar las patatas y cebolla con los huevos batidos. Salpimentar."
        },
        {
          "id": 4,
          "paso": "En la misma sartén con un poco de aceite, verter la mezcla a fuego medio-bajo durante 4-5 minutos."
        },
        {
          "id": 5,
          "paso": "Dar la vuelta con un plato y cocinar el otro lado 3-4 minutos más. Debe quedar jugosa por dentro."
        }
      ],
      "raciones": "4",
      "tiempo_de_elaboracion": "00:35:00",
      "dificultad": "media",
      "imagen": "recetas/tortilla.jpg",
      "visible": true
    }
  },
  {
    "model": "recetas.receta",
    "pk": 2,
    "fields": {
      "usuario": 3,
      "titulo": "Paella valenciana",
      "descripcion": "Paella valenciana auténtica con pollo, conejo, judías verdes y garrofón. Cocinada a leña siguiendo la receta tradicional de Valencia.",
      "ingredientes": [
        { "id": 1, "nombre": "Arroz bomba", "cantidad": "400 g" },
        { "id": 2, "nombre": "Pollo troceado", "cantidad": "600 g" },
        { "id": 3, "nombre": "Conejo troceado", "cantidad": "400 g" },
        { "id": 4, "nombre": "Judías verdes planas", "cantidad": "200 g" },
        { "id": 5, "nombre": "Garrofón (judión blanco)", "cantidad": "100 g" },
        {
          "id": 6,
          "nombre": "Tomate natural rallado",
          "cantidad": "2 unidades"
        },
        { "id": 7, "nombre": "Pimentón dulce", "cantidad": "1 cucharadita" },
        { "id": 8, "nombre": "Azafrán", "cantidad": "1 pizca" },
        { "id": 9, "nombre": "Aceite de oliva", "cantidad": "100 ml" },
        {
          "id": 10,
          "nombre": "Caldo de pollo caliente",
          "cantidad": "1200 ml"
        },
        { "id": 11, "nombre": "Sal", "cantidad": "al gusto" }
      ],
      "elaboracion": [
        {
          "id": 1,
          "paso": "Calentar el aceite en la paellera y dorar el pollo y el conejo a fuego fuerte hasta que estén bien sellados."
        },
        {
          "id": 2,
          "paso": "Añadir las judías verdes y el garrofón, rehogar 5 minutos."
        },
        {
          "id": 3,
          "paso": "Incorporar el tomate rallado y el pimentón, sofreír 2 minutos con cuidado de no quemar el pimentón."
        },
        {
          "id": 4,
          "paso": "Verter el caldo caliente y el azafrán. Llevar a ebullición y cocinar 10 minutos."
        },
        {
          "id": 5,
          "paso": "Añadir el arroz distribuyéndolo en forma de cruz. Cocinar a fuego fuerte 8 minutos y luego a fuego medio 8 minutos más."
        },
        {
          "id": 6,
          "paso": "Dejar reposar 5 minutos tapado con papel de periódico antes de servir."
        }
      ],
      "raciones": "6",
      "tiempo_de_elaboracion": "01:00:00",
      "dificultad": "dificil",
      "imagen": "recetas/paella-valenciana-tradicional.jpg",
      "visible": true
    }
  },
  {
