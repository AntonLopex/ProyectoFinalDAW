          "id": 9,
          "nombre": "Semillas de calabaza tostadas",
          "cantidad": "al gusto"
        }
      ],
      "elaboracion": [
        {
          "id": 1,
          "paso": "Cortar la calabaza en cubos y la cebolla en juliana. Laminar el ajo."
