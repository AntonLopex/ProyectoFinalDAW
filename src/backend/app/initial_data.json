      "usuario": 4,
      "titulo": "Hummus casero",
      "descripcion": "Hummus cremoso y suave hecho desde cero con garbanzos cocidos, tahini y limón. Perfecto como entrante o snack saludable.",
      "ingredientes": [
        { "id": 1, "nombre": "Garbanzos cocidos", "cantidad": "400 g" },
        {
          "id": 2,
          "nombre": "Tahini (pasta de sésamo)",
          "cantidad": "3 cucharadas"
        },
        { "id": 3, "nombre": "Limón (zumo)", "cantidad": "2 unidades" },
        { "id": 4, "nombre": "Ajo", "cantidad": "1 diente" },
        {
          "id": 5,
          "nombre": "Aceite de oliva virgen extra",
          "cantidad": "3 cucharadas"
        },
        { "id": 6, "nombre": "Comino molido", "cantidad": "1/2 cucharadita" },
        { "id": 7, "nombre": "Sal", "cantidad": "al gusto" },
        { "id": 8, "nombre": "Pimentón para decorar", "cantidad": "al gusto" }
      ],
      "elaboracion": [
        {
          "id": 1,
          "paso": "Reservar un poco del líquido de los garbanzos. Pelar los garbanzos quitando la piel para obtener una textura más suave."
        },
        {
          "id": 2,
          "paso": "Triturar todos los ingredientes en el procesador de alimentos hasta obtener una crema homogénea."
        },
        {
          "id": 3,
          "paso": "Si queda muy espeso, añadir el líquido de los garbanzos poco a poco hasta lograr la consistencia deseada."
        },
        { "id": 4, "paso": "Ajustar sal y limón al gusto." },
        {
          "id": 5,
          "paso": "Servir en un plato hondo, hacer un hueco en el centro, añadir un chorrito de aceite de oliva y espolvorear pimentón."
        }
      ],
      "raciones": "4",
      "tiempo_de_elaboracion": "00:15:00",
      "dificultad": "facil",
      "imagen": "recetas/hummus.jpg",
      "visible": true
    }
  },
  {
    "model": "recetas.receta",
    "pk": 4,
    "fields": {
      "usuario": 5,
      "titulo": "Costillas de cerdo a la barbacoa",
      "descripcion": "Costillas de cerdo tiernas y jugosas con salsa barbacoa casera, ahumadas lentamente para conseguir ese sabor irresistible.",
      "ingredientes": [
        { "id": 1, "nombre": "Costillas de cerdo", "cantidad": "1.5 kg" },
        { "id": 2, "nombre": "Salsa barbacoa", "cantidad": "200 ml" },
        { "id": 3, "nombre": "Miel", "cantidad": "2 cucharadas" },
        { "id": 4, "nombre": "Ajo en polvo", "cantidad": "1 cucharadita" },
        { "id": 5, "nombre": "Pimentón ahumado", "cantidad": "1 cucharada" },
        { "id": 6, "nombre": "Sal y pimienta negra", "cantidad": "al gusto" },
        { "id": 7, "nombre": "Zumo de limón", "cantidad": "1 unidad" }
      ],
      "elaboracion": [
        {
          "id": 1,
          "paso": "Mezclar la sal, pimienta, ajo en polvo y pimentón ahumado. Frotar generosamente por toda la pieza de costillas."
        },
        {
          "id": 2,
          "paso": "Envolver en papel de aluminio y dejar marinar en la nevera mínimo 2 horas (mejor toda la noche)."
        },
        {
          "id": 3,
          "paso": "Precalentar el horno a 150°C. Hornear las costillas envueltas en aluminio durante 2,5 horas."
        },
        {
          "id": 4,
          "paso": "Mezclar la salsa barbacoa con la miel y el zumo de limón."
        },
        {
          "id": 5,
          "paso": "Sacar las costillas del aluminio, pintar generosamente con la salsa y gratinar a 200°C durante 15 minutos hasta que caramelicen."
        }
      ],
      "raciones": "4",
      "tiempo_de_elaboracion": "03:00:00",
      "dificultad": "media",
      "imagen": "recetas/costillas.jpg",
      "visible": true
    }
  },
  {
    "model": "recetas.receta",
    "pk": 5,
    "fields": {
      "usuario": 2,
      "titulo": "Tarta de queso al horno estilo Nueva York",
      "descripcion": "La cremosa y clásica tarta de queso horneada, con base de galleta y una textura irresistible. Una de las mejores recetas de repostería que puedes hacer en casa.",
      "ingredientes": [
        {
          "id": 1,
          "nombre": "Queso crema (tipo Philadelphia)",
          "cantidad": "600 g"
        },
        { "id": 2, "nombre": "Azúcar", "cantidad": "150 g" },
        { "id": 3, "nombre": "Huevos", "cantidad": "3 unidades" },
        { "id": 4, "nombre": "Nata líquida para montar", "cantidad": "150 ml" },
        {
          "id": 5,
          "nombre": "Extracto de vainilla",
          "cantidad": "1 cucharadita"
        },
        { "id": 6, "nombre": "Galletas tipo Digestive", "cantidad": "200 g" },
        { "id": 7, "nombre": "Mantequilla fundida", "cantidad": "80 g" }
      ],
      "elaboracion": [
        {
          "id": 1,
          "paso": "Triturar las galletas y mezclar con la mantequilla fundida. Forrar la base de un molde desmontable de 22cm y refrigerar 30 minutos."
        },
        {
          "id": 2,
          "paso": "Precalentar el horno a 160°C. Batir el queso crema con el azúcar hasta obtener una crema suave."
        },
        {
          "id": 3,
          "paso": "Añadir los huevos de uno en uno sin batir en exceso. Incorporar la nata y la vainilla."
        },
        {
          "id": 4,
          "paso": "Verter sobre la base de galleta. Hornear al baño María durante 55-60 minutos (el centro debe quedar ligeramente tembloroso)."
        },
        {
          "id": 5,
          "paso": "Apagar el horno y dejar enfriar dentro con la puerta entreabierta 1 hora."
        },
        { "id": 6, "paso": "Refrigerar mínimo 4 horas antes de servir." }
      ],
      "raciones": "8",
      "tiempo_de_elaboracion": "01:30:00",
      "dificultad": "media",
      "imagen": "recetas/tartaQueso.jpg",
      "visible": true
    }
  },
